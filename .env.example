# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # OAuth Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_AUTH_URL=            # OAuth server URL (e.g. https://auth.yourprovider.com)
VITE_APP_ID=              # OAuth application ID

# ── Backend Auth ───────────────────────────────────────────────
AUTH_URL=                 # OAuth server URL (backend)
OPEN_URL=                 # OAuth Open Platform URL

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app owner — gets role "admin" on first login

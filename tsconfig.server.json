{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@contracts/*": ["./contracts/*"],
      "@contracts/constants": ["./contracts/constants.ts"],
      "@contracts/errors": ["./contracts/errors.ts"],
      "@db/*": ["./db/*"],
      "@db/schema": ["./db/schema.ts"],
      "@db/relations": ["./db/relations.ts"]
    }
  },
  "include": ["api", "contracts", "db"]
}
